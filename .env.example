# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: para webhooks ou jobs server-side com service role (nunca expor no client)
# SUPABASE_SERVICE_ROLE_KEY=

# URL do site (OAuth redirect, links em e-mails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Resend — https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# AbacatePay (PIX) — documentação da plataforma
# -----------------------------------------------------------------------------
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Asaas (cartão / assinaturas) — documentação da plataforma
# -----------------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
