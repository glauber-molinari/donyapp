# Schema SQL versionado em: supabase/migrations/20260403120000_initial_schema.sql
# (cole no SQL Editor do projeto ou use: supabase db push)

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Opcional: se a API Supabase usar outro host além de NEXT_PUBLIC_SUPABASE_URL (ex.: domínio customizado),
# liste origens HTTPS separadas por vírgula para liberar em CSP (connect-src + img-src). Ex.:
# NEXT_PUBLIC_SUPABASE_CSP_ORIGINS=https://auth.seudominio.com
NEXT_PUBLIC_SUPABASE_CSP_ORIGINS=
# Se o domínio customizado da API (ex.: auth.donyapp.com) devolver 503 no localhost, use no dev a URL
# direta do projeto em Dashboard → Settings → API (https://<ref>.supabase.co) até o custom domain estabilizar.
# Service role (Settings → API): necessário para provisionar conta no callback OAuth
# sem depender só de RLS; nunca expor no client nem commitar em repositório público.
# Também usada pelo painel admin (/admin) para métricas e gestão de planos.
# SUPABASE_SERVICE_ROLE_KEY=

# Painel admin (/admin): e-mails do Google/Supabase Auth separados por vírgula (case-insensitive).
# Ex.: DONYAPP_ADMIN_EMAILS=voce@empresa.com
# DONYAPP_ADMIN_EMAILS=

# URL do site (OAuth redirect, links em e-mails). Em produção use https://seu-dominio.com
# (obrigatório no servidor antes de npm run build — evita redirects para localhost:3001 atrás do Nginx).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Suporte in-app (sidebar Ajuda). E-mail padrão: suporte@donyapp.com
# NEXT_PUBLIC_SUPPORT_EMAIL=suporte@donyapp.com
# WhatsApp opcional: apenas dígitos com DDI, sem + (ex.: 5511999999999)
# NEXT_PUBLIC_SUPPORT_WHATSAPP_E164=

# -----------------------------------------------------------------------------
# Google Calendar (integração Agenda — OAuth próprio, além do login Supabase)
# Console: https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client (Web)
# Redirect URI autorizada: {NEXT_PUBLIC_APP_URL}/api/integrations/google/callback
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Segredo para assinar o parâmetro ?state= (CSRF); use string longa aleatória (mín. 16 caracteres).
# GOOGLE_CALENDAR_OAUTH_STATE_SECRET=

# Supabase → Authentication → URL Configuration:
#   Site URL: mesmo valor de NEXT_PUBLIC_APP_URL
#   Redirect URLs: inclua /auth/callback com e sem query (ex.: https://donyapp.com/auth/callback
#   e https://donyapp.com/auth/callback?next=**). O Supabase costuma remover ?next= no e-mail de confirmação;
#   o app guarda invite_token em user_metadata e busca convite pendente pelo e-mail como fallback.
# Authentication → Email Templates: HTML alinhado ao convite (ver docs/supabase-email-templates.md
# e lib/email/supabase-auth-email-templates.ts). Opcional: SMTP customizado via Resend.
# Authentication → Providers → Google: Client ID / Secret (Google Cloud Console)

# -----------------------------------------------------------------------------
# Resend — https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# Remetente verificado no Resend — só o e-mail importa; o nome exibido é sempre "Dony.app" (lib/email/resend-from.ts).
# Ex.: noreply@donyapp.com ou Dony.app <noreply@donyapp.com>
RESEND_FROM=
# E-mail que recebe o aviso quando alguém envia um formulário público (POST /api/formularios/[slug]/submit).
# Sem TEAM_NOTIFY_EMAIL (e sem RESEND_API_KEY + RESEND_FROM), a submissão grava no banco mas não envia e-mail.
TEAM_NOTIFY_EMAIL=

# -----------------------------------------------------------------------------
# Asaas (cartão / link de pagamento / assinaturas) — https://docs.asaas.com
# -----------------------------------------------------------------------------
# Sandbox: https://api-sandbox.asaas.com | Produção: https://api.asaas.com
# Chaves começam com $ e devem ser coladas inteiras (prod: $aact_prod_…, sandbox: $aact_hmlg_…).
#
# Vercel: cole ASAAS_API_KEY sem aspas e sem \ antes do $. Defina ASAAS_API_URL de acordo com a chave.
# A chave precisa da permissão CHECKOUT:WRITE para criar sessões em POST /v3/checkouts.
# .env local (PowerShell evita expandir $): $env:ASAAS_API_KEY='sua_chave_completa'
ASAAS_API_KEY=
ASAAS_API_URL=https://api-sandbox.asaas.com
# Webhook: defina um token forte; o Asaas envia no header asaas-access-token (ou use ?token= na URL).
# No painel, habilite eventos de cobrança, assinatura e checkout (ex.: PAYMENT_CONFIRMED,
# PAYMENT_RECEIVED, SUBSCRIPTION_*, PAYMENT_OVERDUE, CHECKOUT_PAID).
ASAAS_WEBHOOK_TOKEN=
# Opcional (padrão: DonyApp/1.0). O Asaas exige User-Agent nas chamadas à API.
# ASAAS_USER_AGENT=

# Obrigatório para galerias protegidas por senha: segredo HMAC dedicado do cookie
# de sessão (mín. 32 caracteres). Gere com: openssl rand -hex 32
# Sem ele, o acesso por senha falha (não reusa segredos de outros contextos).
# GALLERY_SESSION_SECRET=

# -----------------------------------------------------------------------------
# Cloudflare R2 — Storage de fotos das Galerias
# Setup: crie bucket + API Token (Object Read & Write) no painel da Cloudflare R2.
# Ative CORS no bucket permitindo PUT/GET da origem do app (ver spec-galeria-entrega-dony.md).
# -----------------------------------------------------------------------------
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=dony-galleries
# CLOUDFLARE_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# Opcional: subdomínio público para as imagens (ex.: fotos.donyapp.com).
# Se não definido, as imagens são servidas via rota interna /api/gallery/image/[id].
# CLOUDFLARE_R2_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Feature Flags (Galerias — Pro-only, oculto do Free)
# Liga apenas em ambientes onde a feature está pronta para uso.
# Em produção: tabela feature_flags no Supabase pode ligar/desligar sem redeploy.
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_FF_GALERIAS=true

# -----------------------------------------------------------------------------
# Cron (Vercel) — GET /api/cron/* com Authorization: Bearer …
# Em produção na Vercel é obrigatório; o agendamento em vercel.json usa esse path.
# -----------------------------------------------------------------------------
# CRON_SECRET=
