# Schema SQL versionado em: supabase/migrations/20260403120000_initial_schema.sql
# (cole no SQL Editor do projeto ou use: supabase db push)

# -----------------------------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (Settings → API): necessário para provisionar conta no callback OAuth
# sem depender só de RLS; nunca expor no client nem commitar em repositório público.
# SUPABASE_SERVICE_ROLE_KEY=

# URL do site (OAuth redirect, links em e-mails). Em produção use https://seu-dominio.com
# (obrigatório no servidor antes de npm run build — evita redirects para localhost:3001 atrás do Nginx).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Google Calendar (integração Agenda — OAuth próprio, além do login Supabase)
# Console: https://console.cloud.google.com/apis/credentials — OAuth 2.0 Client (Web)
# Redirect URI autorizada: {NEXT_PUBLIC_APP_URL}/api/integrations/google/callback
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Segredo para assinar o parâmetro ?state= (CSRF); use string longa aleatória (mín. 16 caracteres).
# GOOGLE_CALENDAR_OAUTH_STATE_SECRET=

# Supabase → Authentication → URL Configuration:
#   Site URL: mesmo valor de NEXT_PUBLIC_APP_URL
#   Redirect URLs: http://localhost:3000/auth/callback (+ URL de produção depois)
# Authentication → Providers → Google: Client ID / Secret (Google Cloud Console)

# -----------------------------------------------------------------------------
# Resend — https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# Asaas (cartão / link de pagamento / assinaturas) — https://docs.asaas.com
# -----------------------------------------------------------------------------
# Sandbox: https://api-sandbox.asaas.com | Produção: https://api.asaas.com
# Chaves começam com $. No Next.js o $ pode ser expandido e a chave fica vazia — use \ no primeiro $:
#   ASAAS_API_KEY=\$aact_hmlg_...
# (ou aspas simples em volta do valor inteiro, conforme o parser aceitar no seu SO)
ASAAS_API_KEY=
ASAAS_API_URL=https://api-sandbox.asaas.com
# Webhook: defina um token forte; o Asaas envia no header asaas-access-token (ou use ?token= na URL).
# No painel, habilite eventos de cobrança e assinatura (ex.: PAYMENT_CONFIRMED, PAYMENT_RECEIVED,
# SUBSCRIPTION_CREATED, SUBSCRIPTION_UPDATED, SUBSCRIPTION_DELETED, PAYMENT_OVERDUE).
ASAAS_WEBHOOK_TOKEN=
# Opcional (padrão: DonyApp/1.0). O Asaas exige User-Agent nas chamadas à API.
# ASAAS_USER_AGENT=
